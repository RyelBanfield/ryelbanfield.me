---
import Layout from "../../layouts/Layout.astro";

const projects = [
  {
    name: "QLink",
    slug: "qlink",
  },
  {
    name: "View Finder",
    slug: "view-finder",
  },
];
---

<Layout title="Ryel's Portfolio">
  <div class="grid grid-cols-1 gap-6">
    {
      projects.map((project) => (
        <div>
          <a href={`/portfolio/${project.slug}`}>{project.name}</a>
        </div>
      ))
    }
  </div>
</Layout>
