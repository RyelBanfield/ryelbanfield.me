---
import Screenshot from "../images/Screenshot.png";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary Meta Tags -->
    <meta name="title" content="Ryel's Portfolio & Blog." />
    <meta
      name="description"
      content="Software Developer, Entrepreneur, Digital Nomad. 2+ years of experience and a track record of building successful web and mobile applications."
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ryelbanfield.me/" />
    <meta property="og:title" content="Ryel's Portfolio & Blog." />
    <meta
      property="og:description"
      content="Software Developer, Entrepreneur, Digital Nomad. 2+ years of experience and a track record of building successful web and mobile applications."
    />
    <meta property="og:image" content={Screenshot as unknown as string} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://ryelbanfield.me/" />
    <meta property="twitter:title" content="Ryel's Portfolio & Blog." />
    <meta
      property="twitter:description"
      content="Software Developer, Entrepreneur, Digital Nomad. 2+ years of experience and a track record of building successful web and mobile applications."
    />
    <meta property="twitter:image" content={Screenshot as unknown as string} />

    <title>{title}</title>
  </head>
  <body
    class="mx-auto flex min-h-screen max-w-3xl flex-col bg-neutral-900 p-6 text-neutral-50"
  >
    <Nav />
    <main class="fade-in-bottom mb-9 flex-grow pt-9">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .fade-in-bottom {
    -webkit-animation: fade-in-bottom 0.6s cubic-bezier(0.39, 0.575, 0.565, 1)
      both;
    animation: fade-in-bottom 0.6s cubic-bezier(0.39, 0.575, 0.565, 1) both;
  }

  /* ----------------------------------------------
 * Generated by Animista on 2023-2-4 15:54:31
 * Licensed under FreeBSD License.
 * See http://animista.net/license for more info. 
 * w: http://animista.net, t: @cssanimista
 * ---------------------------------------------- */

  /**
 * ----------------------------------------
 * animation fade-in-bottom
 * ----------------------------------------
 */
  @-webkit-keyframes fade-in-bottom {
    0% {
      -webkit-transform: translateY(50px);
      transform: translateY(50px);
      opacity: 0;
    }
    100% {
      -webkit-transform: translateY(0);
      transform: translateY(0);
      opacity: 1;
    }
  }
  @keyframes fade-in-bottom {
    0% {
      -webkit-transform: translateY(50px);
      transform: translateY(50px);
      opacity: 0;
    }
    100% {
      -webkit-transform: translateY(0);
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
