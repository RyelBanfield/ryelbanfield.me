---
const pathname = new URL(Astro.request.url).pathname;

const pages = [
  { name: "Home", route: "/", active: pathname === "/" },
  {
    name: "Portfolio",
    route: "/portfolio",
    active: pathname.includes("/portfolio"),
  },
  { name: "Blog", route: "/blog", active: pathname.includes("/blog") },
];
---

<nav class="flex gap-3 mb-12">
  {
    pages.map((page) => (
      <a
        rel="prefetch"
        href={page.route}
        class={`text-lg font-semibold transition-all hover:animate-pulse ${
          page.active && "text-neutral-400"
        }`}
      >
        {page.name}
      </a>
    ))
  }
</nav>
